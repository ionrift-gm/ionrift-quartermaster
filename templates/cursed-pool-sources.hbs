<form class="ionrift-loot-pool-config ionrift-cursed-pool-sources">
    <p class="pool-instructions">
        Select which item compendiums the Cursed Pool draws from.
        All items in the selected compendiums are available for import.
    </p>

    <div class="scroll-forge-toolbar">
        <button type="button" class="cache-btn-accent cursed-pool-select-all">
            <i class="fas fa-check-double"></i> Select all
        </button>
        <button type="button" class="cache-btn-accent cursed-pool-select-none">
            <i class="fas fa-times"></i> Select none
        </button>
    </div>

    <div class="cursed-pool-sources-scroll">
        {{#each groups}}
        <div class="pool-group">
            <div class="pool-group-header">
                <i class="fas fa-box-archive"></i> {{this.label}}
            </div>
            {{#each this.packs}}
            <label class="pool-pack-row">
                <input type="checkbox" name="pack-{{this.id}}" {{#if this.enabled}}checked{{/if}} />
                <span class="pool-pack-label">{{this.label}}</span>
                <span class="pool-pack-id">{{this.id}}{{#if this.count}} ({{this.count}} items){{/if}}</span>
            </label>
            {{/each}}
        </div>
        {{/each}}
    </div>

    <footer class="pool-footer">
        <button type="submit" class="cache-btn-accent">
            <i class="fas fa-save"></i> Save sources
        </button>
    </footer>
</form>
